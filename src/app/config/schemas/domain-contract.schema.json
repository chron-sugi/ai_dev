{
  "$defs": {
    "AdrReference": {
      "additionalProperties": false,
      "description": "Optional provenance linking a contract decision to an ADR.",
      "properties": {
        "id": {
          "pattern": "^ADR-[0-9]{4}$",
          "title": "Id",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        }
      },
      "required": [
        "id",
        "path"
      ],
      "title": "AdrReference",
      "type": "object"
    },
    "Approval": {
      "additionalProperties": false,
      "description": "Actor and time that approved a scaffoldable contract.",
      "properties": {
        "actor": {
          "enum": [
            "human",
            "agent"
          ],
          "title": "Actor",
          "type": "string"
        },
        "approved_at": {
          "format": "date-time",
          "title": "Approved At",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "actor",
        "name",
        "approved_at"
      ],
      "title": "Approval",
      "type": "object"
    },
    "BackendComponent": {
      "additionalProperties": false,
      "description": "Complete declarations consumed by the Python backend scaffold.",
      "properties": {
        "config": {
          "anyOf": [
            {
              "$ref": "#/$defs/PythonConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "jobs": {
          "anyOf": [
            {
              "$ref": "#/$defs/Jobs"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "package": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Package",
          "type": "string"
        },
        "persistence": {
          "anyOf": [
            {
              "$ref": "#/$defs/Persistence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "public_api": {
          "items": {
            "$ref": "#/$defs/PythonSymbol"
          },
          "minItems": 1,
          "title": "Public Api",
          "type": "array"
        },
        "service": {
          "anyOf": [
            {
              "$ref": "#/$defs/Service"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "testing": {
          "anyOf": [
            {
              "$ref": "#/$defs/TestingSurface"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "package",
        "public_api"
      ],
      "title": "BackendComponent",
      "type": "object"
    },
    "BackendHttpProvider": {
      "additionalProperties": false,
      "description": "Root HTTP provider declarations for the package-local FastAPI adapter.",
      "properties": {
        "dependency_providers": {
          "items": {
            "$ref": "#/$defs/DependencyProvider"
          },
          "title": "Dependency Providers",
          "type": "array"
        },
        "endpoint_ids": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Endpoint Ids",
          "type": "array"
        }
      },
      "required": [
        "endpoint_ids"
      ],
      "title": "BackendHttpProvider",
      "type": "object"
    },
    "CrossSliceEdge": {
      "additionalProperties": false,
      "description": "Explicit FSD @x edge granted by the contract.",
      "properties": {
        "adr": {
          "anyOf": [
            {
              "pattern": "^ADR-[0-9]{4}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Adr"
        },
        "exports": {
          "items": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Exports",
          "type": "array"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "target": {
          "minLength": 1,
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "target",
        "exports",
        "reason"
      ],
      "title": "CrossSliceEdge",
      "type": "object"
    },
    "DependencyEdge": {
      "additionalProperties": false,
      "description": "Explicitly granted dependency edge to another domain.",
      "properties": {
        "adr": {
          "anyOf": [
            {
              "pattern": "^ADR-[0-9]{4}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Adr"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "target": {
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "target",
        "reason"
      ],
      "title": "DependencyEdge",
      "type": "object"
    },
    "DependencyProvider": {
      "additionalProperties": false,
      "description": "FastAPI dependency provider owned by a domain adapter.",
      "properties": {
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "name": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Name",
          "type": "string"
        },
        "signature": {
          "minLength": 1,
          "title": "Signature",
          "type": "string"
        }
      },
      "required": [
        "name",
        "signature",
        "description"
      ],
      "title": "DependencyProvider",
      "type": "object"
    },
    "DomainDependencies": {
      "additionalProperties": false,
      "description": "All explicitly granted backend and frontend dependency edges.",
      "properties": {
        "backend": {
          "items": {
            "$ref": "#/$defs/DependencyEdge"
          },
          "title": "Backend",
          "type": "array"
        },
        "frontend": {
          "items": {
            "$ref": "#/$defs/CrossSliceEdge"
          },
          "title": "Frontend",
          "type": "array"
        }
      },
      "title": "DomainDependencies",
      "type": "object"
    },
    "DomainTypes": {
      "additionalProperties": false,
      "description": "Shared domain vocabulary declared independently of a component.",
      "properties": {
        "aliases": {
          "items": {
            "$ref": "#/$defs/TypeAliasDeclaration"
          },
          "title": "Aliases",
          "type": "array"
        },
        "enums": {
          "items": {
            "$ref": "#/$defs/EnumDeclaration"
          },
          "title": "Enums",
          "type": "array"
        },
        "errors": {
          "items": {
            "$ref": "#/$defs/ErrorDeclaration"
          },
          "title": "Errors",
          "type": "array"
        },
        "models": {
          "items": {
            "$ref": "#/$defs/ModelDeclaration"
          },
          "title": "Models",
          "type": "array"
        }
      },
      "title": "DomainTypes",
      "type": "object"
    },
    "EnumDeclaration": {
      "additionalProperties": false,
      "description": "Enum vocabulary generated in the backend models module.",
      "properties": {
        "base": {
          "enum": [
            "StrEnum",
            "Enum",
            "IntEnum"
          ],
          "title": "Base",
          "type": "string"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "members": {
          "minProperties": 1,
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*$": {
              "minLength": 1,
              "type": "string"
            }
          },
          "title": "Members",
          "type": "object"
        },
        "name": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name",
        "base",
        "members",
        "description"
      ],
      "title": "EnumDeclaration",
      "type": "object"
    },
    "ErrorDeclaration": {
      "additionalProperties": false,
      "description": "Python domain error declaration.",
      "properties": {
        "base": {
          "default": "Exception",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Base",
          "type": "string"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "name": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name",
        "description"
      ],
      "title": "ErrorDeclaration",
      "type": "object"
    },
    "FrontendApiFunction": {
      "additionalProperties": false,
      "description": "Client function wrapping a generated API operation.",
      "properties": {
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "endpoint_id": {
          "minLength": 1,
          "title": "Endpoint Id",
          "type": "string"
        },
        "name": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Name",
          "type": "string"
        },
        "signature": {
          "minLength": 1,
          "title": "Signature",
          "type": "string"
        }
      },
      "required": [
        "name",
        "endpoint_id",
        "signature",
        "description"
      ],
      "title": "FrontendApiFunction",
      "type": "object"
    },
    "FrontendApiSegment": {
      "additionalProperties": false,
      "description": "Declarations that activate a frontend api segment.",
      "properties": {
        "endpoint_ids": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Endpoint Ids",
          "type": "array"
        },
        "functions": {
          "items": {
            "$ref": "#/$defs/FrontendApiFunction"
          },
          "minItems": 1,
          "title": "Functions",
          "type": "array"
        }
      },
      "required": [
        "endpoint_ids",
        "functions"
      ],
      "title": "FrontendApiSegment",
      "type": "object"
    },
    "FrontendComponent": {
      "additionalProperties": false,
      "description": "Complete declarations consumed by the FSD slice scaffold.",
      "properties": {
        "backend_package": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Backend Package"
        },
        "layer": {
          "enum": [
            "pages",
            "widgets",
            "features",
            "entities"
          ],
          "title": "Layer",
          "type": "string"
        },
        "placement": {
          "$ref": "#/$defs/LayerPlacement"
        },
        "public_api": {
          "items": {
            "$ref": "#/$defs/FrontendExport"
          },
          "minItems": 1,
          "title": "Public Api",
          "type": "array"
        },
        "route": {
          "anyOf": [
            {
              "$ref": "#/$defs/FrontendRoute"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "segments": {
          "$ref": "#/$defs/FrontendSegments"
        },
        "slice": {
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "title": "Slice",
          "type": "string"
        }
      },
      "required": [
        "slice",
        "layer",
        "placement",
        "public_api",
        "segments"
      ],
      "title": "FrontendComponent",
      "type": "object"
    },
    "FrontendExport": {
      "additionalProperties": false,
      "description": "Exact TypeScript export exposed by a slice public API.",
      "properties": {
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "from_segment": {
          "enum": [
            "ui",
            "api",
            "model",
            "lib"
          ],
          "title": "From Segment",
          "type": "string"
        },
        "kind": {
          "enum": [
            "component",
            "function",
            "type",
            "constant",
            "hook"
          ],
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Name",
          "type": "string"
        },
        "signature": {
          "minLength": 1,
          "title": "Signature",
          "type": "string"
        }
      },
      "required": [
        "name",
        "kind",
        "from_segment",
        "signature",
        "description"
      ],
      "title": "FrontendExport",
      "type": "object"
    },
    "FrontendRoute": {
      "additionalProperties": false,
      "description": "Page route registration declaration.",
      "properties": {
        "export": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Export",
          "type": "string"
        },
        "path": {
          "pattern": "^/",
          "title": "Path",
          "type": "string"
        }
      },
      "required": [
        "path",
        "export"
      ],
      "title": "FrontendRoute",
      "type": "object"
    },
    "FrontendSegments": {
      "additionalProperties": false,
      "description": "Explicit optional FSD segments; presence means create.",
      "properties": {
        "api": {
          "anyOf": [
            {
              "$ref": "#/$defs/FrontendApiSegment"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "lib": {
          "anyOf": [
            {
              "$ref": "#/$defs/LibSegment"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "model": {
          "anyOf": [
            {
              "$ref": "#/$defs/ModelSegment"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "ui": {
          "anyOf": [
            {
              "$ref": "#/$defs/UiSegment"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "FrontendSegments",
      "type": "object"
    },
    "HelperDeclaration": {
      "additionalProperties": false,
      "description": "Slice-specific helper shared by at least two modules.",
      "properties": {
        "consumers": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 2,
          "title": "Consumers",
          "type": "array"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "name": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Name",
          "type": "string"
        },
        "signature": {
          "minLength": 1,
          "title": "Signature",
          "type": "string"
        }
      },
      "required": [
        "name",
        "signature",
        "consumers",
        "description"
      ],
      "title": "HelperDeclaration",
      "type": "object"
    },
    "HttpEndpoint": {
      "additionalProperties": false,
      "description": "Shared HTTP interface used by backend and frontend components.",
      "properties": {
        "auth": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Auth"
        },
        "errors": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Errors",
          "type": "array"
        },
        "id": {
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "method": {
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ],
          "title": "Method",
          "type": "string"
        },
        "operation": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Operation",
          "type": "string"
        },
        "path": {
          "pattern": "^/",
          "title": "Path",
          "type": "string"
        },
        "request_type": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Request Type"
        },
        "response_type": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Response Type",
          "type": "string"
        },
        "status_code": {
          "maximum": 599,
          "minimum": 100,
          "title": "Status Code",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "method",
        "path",
        "operation",
        "response_type",
        "status_code"
      ],
      "title": "HttpEndpoint",
      "type": "object"
    },
    "HttpInterface": {
      "additionalProperties": false,
      "description": "Canonical endpoint declarations shared across component seams.",
      "properties": {
        "backend": {
          "anyOf": [
            {
              "$ref": "#/$defs/BackendHttpProvider"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "endpoints": {
          "items": {
            "$ref": "#/$defs/HttpEndpoint"
          },
          "minItems": 1,
          "title": "Endpoints",
          "type": "array"
        },
        "schemas": {
          "items": {
            "$ref": "#/$defs/ModelDeclaration"
          },
          "minItems": 1,
          "title": "Schemas",
          "type": "array"
        }
      },
      "required": [
        "schemas",
        "endpoints"
      ],
      "title": "HttpInterface",
      "type": "object"
    },
    "Invariant": {
      "additionalProperties": false,
      "description": "Checkable domain truth that implementations must preserve.",
      "properties": {
        "applies_to": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Applies To",
          "type": "array"
        },
        "enforcement": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Enforcement"
        },
        "id": {
          "pattern": "^I-[0-9]{3}$",
          "title": "Id",
          "type": "string"
        },
        "statement": {
          "minLength": 1,
          "title": "Statement",
          "type": "string"
        }
      },
      "required": [
        "id",
        "statement"
      ],
      "title": "Invariant",
      "type": "object"
    },
    "Job": {
      "additionalProperties": false,
      "description": "Non-HTTP entry point that activates jobs.py.",
      "properties": {
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "name": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Name",
          "type": "string"
        },
        "signature": {
          "minLength": 1,
          "title": "Signature",
          "type": "string"
        },
        "trigger": {
          "minLength": 1,
          "title": "Trigger",
          "type": "string"
        }
      },
      "required": [
        "name",
        "signature",
        "trigger",
        "description"
      ],
      "title": "Job",
      "type": "object"
    },
    "Jobs": {
      "additionalProperties": false,
      "description": "Declared non-HTTP entry points.",
      "properties": {
        "entries": {
          "items": {
            "$ref": "#/$defs/Job"
          },
          "minItems": 1,
          "title": "Entries",
          "type": "array"
        }
      },
      "required": [
        "entries"
      ],
      "title": "Jobs",
      "type": "object"
    },
    "LayerPlacement": {
      "additionalProperties": false,
      "description": "Reason and consumers supporting the selected FSD layer.",
      "properties": {
        "consumers": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Consumers",
          "type": "array"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "reason"
      ],
      "title": "LayerPlacement",
      "type": "object"
    },
    "LibSegment": {
      "additionalProperties": false,
      "description": "Declarations that activate a frontend lib segment.",
      "properties": {
        "helpers": {
          "items": {
            "$ref": "#/$defs/HelperDeclaration"
          },
          "minItems": 1,
          "title": "Helpers",
          "type": "array"
        }
      },
      "required": [
        "helpers"
      ],
      "title": "LibSegment",
      "type": "object"
    },
    "ModelDeclaration": {
      "additionalProperties": false,
      "description": "Python model that the scaffold must declare exactly.",
      "properties": {
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "fields": {
          "items": {
            "$ref": "#/$defs/TypedField"
          },
          "title": "Fields",
          "type": "array"
        },
        "name": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name",
        "description"
      ],
      "title": "ModelDeclaration",
      "type": "object"
    },
    "ModelSegment": {
      "additionalProperties": false,
      "description": "Declarations that activate a frontend model segment.",
      "properties": {
        "state": {
          "items": {
            "$ref": "#/$defs/StateDeclaration"
          },
          "minItems": 1,
          "title": "State",
          "type": "array"
        }
      },
      "required": [
        "state"
      ],
      "title": "ModelSegment",
      "type": "object"
    },
    "Persistence": {
      "additionalProperties": false,
      "description": "Persistent state that activates tables.py and store.py.",
      "properties": {
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "tables": {
          "items": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Tables",
          "type": "array"
        }
      },
      "required": [
        "tables",
        "description"
      ],
      "title": "Persistence",
      "type": "object"
    },
    "PythonConfig": {
      "additionalProperties": false,
      "description": "Tunables that activate a domain config.py module.",
      "properties": {
        "tunables": {
          "items": {
            "$ref": "#/$defs/Tunable"
          },
